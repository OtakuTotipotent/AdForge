# Auto detect text files
* text=auto

# Source files
*.js text
*.jsx text
*.ts text
*.tsx text
*.css text
*.scss text
*.html text
*.json text
*.md text
*.yml text
*.yaml text

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary

# Videos
*.mp4 binary
*.mov binary
*.webm binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
